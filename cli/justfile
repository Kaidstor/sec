_default:
    @just --list

# Собрать бинарь в ../bin/sec (туда же смотрит wrapper sec.sh)
build:
    go build -o ../bin/sec .

# Установить в ~/go/bin (должен быть в PATH) — для прямого вызова `sec`
install:
    go install .

# Проверки: формат, vet, build
check:
    gofmt -l .
    go vet ./...
    go build -o /dev/null .

# Прогнать команду: just run ls
run *args:
    go run . {{args}}

# Собрать бинарь с версией из git-тега (иначе version=dev)
build-versioned:
    go build -ldflags "-X github.com/kaidstor/sec/internal/command.version=$(git describe --tags --always --dirty 2>/dev/null || echo dev)" -o ../bin/sec .

# Проверить конфиг релиза (нужен goreleaser; запускается из корня репо)
release-check:
    cd .. && goreleaser check

# Сухой прогон релиза без публикации: все бинарники + формула в ../dist
release-snapshot:
    cd .. && goreleaser release --snapshot --clean
